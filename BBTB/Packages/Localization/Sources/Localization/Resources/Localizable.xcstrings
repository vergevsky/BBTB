        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Edge" } }
      }
    },
    "settings.antiDpi.stun.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Block STUN traffic" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Блокировать STUN-трафик" } }
      }
    },
    "settings.antiDpi.stun.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Protects against WebRTC IP leaks. Will break browser-based video calls (Google Meet, Zoom, Discord web). Does not affect native apps." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Защищает от утечки IP через WebRTC. Сломает видеозвонки в браузере (Google Meet, Zoom, Discord-web). Не влияет на нативные приложения." } }
      }
    },
    "settings.antiDpi.stun.confirm.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Block STUN traffic?" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Включить блокировку STUN?" } }
      }
    },
    "settings.antiDpi.stun.confirm.message" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Browser video calls will stop working while this is enabled. Native apps (FaceTime, Telegram) are unaffected." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Видеозвонки в браузере перестанут работать, пока опция включена. Нативные приложения (FaceTime, Telegram) не пострадают." } }
      }
    },
    "settings.antiDpi.stun.confirm.action" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Включить" } }
      }
    },
    "settings.antiDpi.stun.confirm.cancel" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Cancel" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Отмена" } }
      }
    },
    "settings.security.certPinning.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Subscription certificate pinning" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Pinning сертификата подписки" } }
      }
    },
    "settings.security.certPinning.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Protects the subscription endpoint connection from certificate substitution. If pinning breaks after a server certificate change — disable temporarily." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Защищает соединение с панелью подписок от подмены сертификата. Если pinning сломался после смены сертификата на стороне сервера — временно отключите." } }
      }
    },
    "settings.security.enforceRoutes.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Force route enforcement (macOS)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Принудительная маршрутизация (macOS)" } }
      }
    },
    "settings.security.enforceRoutes.footer.on" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "All traffic goes through VPN. If the tunnel fails — the OS blocks traffic until it recovers. Safer to keep enabled." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Весь трафик идёт через VPN. Если туннель упал — ОС блокирует сетевой трафик до восстановления. Безопаснее держать включённым." } }
      }
    },
    "settings.security.enforceRoutes.footer.off" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Off = traffic goes direct if VPN fails. IP leaks are possible." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Выкл = трафик идёт напрямую если VPN упал. Возможны утечки IP." } }
      }
    },
    "settings.rules.viewer.section" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Rules" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Правила" } }
      }
    },
    "onboarding.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Bring back the bug" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Верни жука" } }
      }
    },
    "onboarding.subtitle" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "One-tap freedom from Russian DPI." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Один тап для свободного интернета без ТСПУ." } }
      }
    },
    "onboarding.cta_paste" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add from clipboard" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавить из буфера" } }
      }
    },
    "onboarding.cta_qr" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Scan QR code" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Сканировать QR-код" } }
      }
    },
    "onboarding.a11y_hint" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add your first server to start using VPN." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавьте первый сервер, чтобы начать пользоваться VPN." } }
      }
    },
    "onboarding.hint" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Add configuration" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Добавьте конфигурацию" } }
      }
    },
    "onboarding.skip" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Skip" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пропустить" } }
      }
    },
    "help.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Help" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Помощь" } }
      }
    },
    "help.entry.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Help" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Помощь" } }
      }
    },
    "help.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If you have not found an answer — send a diagnostic log via Settings → Diagnostics." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Если не нашли ответ — отправьте лог разработчику через раздел «Диагностика» в настройках." } }
      }
    },
    "help.faq1.question" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "How do I add a server?" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Как добавить сервер?" } }
      }
    },
    "help.faq1.answer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Open the «+» menu on the main screen. You can paste a config link from the clipboard, scan a QR code, or pick a .json/.yaml file. Subscription URLs (those ending with a token) are supported — the app will fetch the list and add all servers in one go." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Откройте меню «+» на главном экране. Можно вставить ссылку с конфигурацией из буфера обмена, отсканировать QR-код или выбрать файл .json/.yaml. Поддерживаются и подписочные ссылки (subscription) — приложение само скачает список и добавит все серверы сразу." } }
      }
    },
    "help.faq2.question" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "What if it does not connect?" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Что делать, если не подключается?" } }
      }
    },
    "help.faq2.answer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Try another server from the list — auto-failover usually finds a working one on its own. If everything is unavailable, your provider may be blocking the server's IP — switch the transport (in server details) or wait for rules to update (every 6 hours). When nothing helps — send the log to the developer via Settings → Diagnostics." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Попробуйте другой сервер из списка — авто-failover обычно сам найдёт рабочий. Если всё недоступно — провайдер может блокировать IP сервера. Переключите транспорт (в деталях сервера) или подождите обновления правил (раз в 6 часов). Если ничего не помогает — отправьте лог разработчику через «Диагностика» в настройках." } }
      }
    },
    "help.faq3.question" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "What is a WebRTC leak?" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Что такое WebRTC (веб-RTC утечка)?" } }
      }
    },
    "help.faq3.answer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "WebRTC is a browser technology for voice and video calls that can reveal your real IP address even when a VPN is on — through direct peer-to-peer connections. To protect yourself, enable «Block STUN» in Settings → Anti-DPI: it stops WebRTC from probing peers outside the tunnel." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "WebRTC — браузерная технология голосовых и видеозвонков, которая может раскрыть ваш реальный IP даже при включённом VPN — через прямое peer-to-peer соединение. Чтобы защититься, включите «Блокировать STUN» в Настройках → Anti-DPI: это запрещает WebRTC отправлять запросы напрямую, минуя туннель." } }
      }
    },
    "help.faq4.question" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Why do 22 Russian apps detect that I am on a VPN?" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Почему 22 приложения из РФ видят, что я под VPN?" } }
      }
    },
    "help.faq4.answer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Banking, government and gosuslugi apps actively detect VPNs to comply with regulations. They check the routing table, TLS fingerprint, and reachable IP ranges. The app cannot hide a VPN from these checks completely. The full list is documented in wiki/vpn-detection-by-apps.md inside the project. Recommendation: disable VPN before opening such an app." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Банковские, государственные приложения и «Госуслуги» активно детектируют VPN, чтобы соответствовать требованиям регуляторов. Они проверяют таблицу маршрутизации, TLS-отпечаток и доступность определённых IP. Скрыть VPN от таких проверок полностью невозможно. Полный список — см. wiki/vpn-detection-by-apps.md в проекте. Рекомендация: отключайте VPN перед использованием таких приложений." } }
      }
    },
    "help.faq5.question" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "What are the limits of the messenger detection?" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Какие у детектирования есть ограничения?" } }
      }
    },
    "help.faq5.answer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "MAX-messenger detection is silent and best-effort: the app probes a list of candidate URL schemes and bundle identifiers on cold start and only writes the result to the log. There is no UI signal — neither false positives nor false negatives change app behaviour. If the messenger is renamed or updated by VK, the candidate list may need a one-line patch in a future release." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Детектирование мессенджера MAX — тихое и best-effort: при запуске приложение пробует список кандидат-схем URL и bundle-идентификаторов, результат пишется только в лог. В UI ничего не показывается — ни ложные срабатывания, ни пропуски не меняют поведение приложения. Если VK переименует мессенджер — список кандидатов придётся обновить в следующем релизе." } }
      }
    },
