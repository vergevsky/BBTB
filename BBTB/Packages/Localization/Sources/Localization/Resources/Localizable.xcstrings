    "deep_link.error.unhandled" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This link isn't supported. Copy the subscription URL and import it via the + menu." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ссылка не поддерживается. Скопируйте подписку и импортируйте через меню «+»." } }
      }
    },
    "deep_link.error.missing_parameter" : {
