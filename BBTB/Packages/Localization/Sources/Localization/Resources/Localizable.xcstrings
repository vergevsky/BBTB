        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Импорт не удался: %@. Проверьте интернет и попробуйте ещё раз через меню «+»." } }
      }
    },
    "settings.antiDpi.section" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Anti-DPI" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Anti-DPI" } }
      }
    },
    "settings.antiDpi.sectionFooter" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Anti-DPI settings. Applied on next connection." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Настройки для обхода ТСПУ. Применяются при следующем подключении." } }
      }
    },
    "settings.antiDpi.cdn.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "CDN fronting" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "CDN-фронтинг" } }
      }
    },
    "settings.antiDpi.cdn.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Masks traffic as ordinary websites via Cloudflare/Fastly. Applies only to servers that include CDN data in their subscription." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Маскирует трафик под обычные сайты через Cloudflare/Fastly. Применяется только к серверам, у которых в подписке указаны CDN-данные." } }
      }
    },
    "settings.antiDpi.mux.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Multiplexing (Mux)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Мультиплексирование (Mux)" } }
      }
    },
    "settings.antiDpi.mux.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Combines multiple connections into one — reduces TLS handshakes. Works for VLESS+TLS, Trojan, Shadowsocks-2022. Not compatible with Reality/Vision/TUIC/Hysteria2 — ignored for those." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Объединяет несколько соединений в одно — снижает количество TLS-рукопожатий. Работает для VLESS+TLS, Trojan и Shadowsocks-2022. Несовместимо с Reality/Vision/TUIC/Hysteria2 — для них настройка игнорируется." } }
      }
    },
    "settings.antiDpi.utls.label" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "TLS fingerprint (uTLS)" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "TLS-отпечаток (uTLS)" } }
      }
    },
    "settings.antiDpi.utls.footer" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Mimics a popular browser's TLS handshake. \"Random\" is the recommended default — fingerprint changes on each connection." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Имитирует TLS-рукопожатие популярного браузера. «Случайный» — рекомендация по умолчанию: отпечаток меняется при каждом подключении." } }
      }
    },
    "settings.antiDpi.utls.option.random" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Random" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Случайный" } }
      }
    },
    "settings.antiDpi.utls.option.chrome" : {
      "localizations" : {
