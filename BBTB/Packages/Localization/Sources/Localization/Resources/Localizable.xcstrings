    "settings.antiDpi.utls.option.android" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Android" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Android" } }
      }
